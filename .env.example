# Copy to .env.local (git-ignored) and fill in real values. NEVER commit secrets.
# On Vercel, set these in Dashboard → Project → Settings → Environment Variables.

# --- Neon Postgres -----------------------------------------------------------
# Connection string (also used by the rate limiter's rate_limits table).
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# --- Anthropic (Claude) ------------------------------------------------------
# Server-side only. IMPORTANT: also set a MONTHLY SPEND CAP in the Anthropic
# Console (Billing → Usage limits) — the hard backstop that caps the bill even
# if rate limiting is bypassed (SPEC_API_HARDENING §0).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- CORS allowlist (SPEC_API_HARDENING §2) ----------------------------------
# Comma-separated origins allowed to read API responses from a browser.
# No trailing slashes. If unset, the API falls back to the prod origin only.
# CORS is browser-enforced only — rate limiting is what protects the bill.
ALLOWED_ORIGINS=https://affina-space.vercel.app,http://localhost:5173

# --- Resend email + magic-link auth (SPEC_RESEND_AUTH §9) --------------------
# Resend API key (domain affina.space verified, EU region).
RESEND_API_KEY=re_xxxxxxxx
# Verified From identity — must be on the verified domain.
EMAIL_FROM=Affina <hello@affina.space>
# Random 32+ byte string for signing session cookies (HMAC). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate_a_32_byte_hex_string
# Base URL for building magic links + email CTAs.
APP_URL=https://affina-space.vercel.app
# Protects the daily lifecycle-email cron (api/cron.ts, SPEC_EMAILS §3). Vercel Cron
# auto-sends it as `Authorization: Bearer <CRON_SECRET>`. Generate like SESSION_SECRET.
CRON_SECRET=generate_a_32_byte_hex_string

# --- Stripe subscription (SPEC_STRIPE §9) ------------------------------------
# Test-mode keys first (card 4242 4242 4242 4242), then swap to live at go-live.
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# From Dashboard → Developers → Webhooks after registering the endpoint
# (https://affina-space.vercel.app/api/stripe). Required for signature verification.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
# The two recurring Price IDs (§1). Amounts live in Stripe; code only references the IDs.
STRIPE_PRICE_QUARTERLY=price_xxxxxxxx   # €360 / 3 months — first term, upfront
STRIPE_PRICE_ANNUAL=price_xxxxxxxx      # €1200 / year — renewal after month 3

# --- Observability (SPEC audit P7) --------------------------------------------
# Error tracking + alerting. Both OPTIONAL and independent — if neither is set,
# captureError still emits a structured JSON error line to the Vercel function logs
# (no external calls, zero cost). Set either to get real alerting:
#
# A Slack or Discord "Incoming Webhook" URL — get a real-time "🔴 Affina error" ping
# the moment a 5xx / webhook / AI failure happens in prod. Simplest option.
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
#
# A Sentry DSN (project → Settings → Client Keys) for a full error dashboard. Sent via
# Sentry's HTTP envelope API — no SDK, so no cold-start/bundle cost.
# SENTRY_DSN=https://<publicKey>@<org>.ingest.sentry.io/<projectId>
