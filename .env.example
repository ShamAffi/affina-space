# Copy to .env.local (git-ignored) and fill in real values. NEVER commit secrets.
# On Vercel, set these in Dashboard → Project → Settings → Environment Variables.

# --- Neon Postgres -----------------------------------------------------------
# Connection string (also used by the rate limiter's rate_limits table).
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# --- Anthropic (Claude) ------------------------------------------------------
# Server-side only. IMPORTANT: also set a MONTHLY SPEND CAP in the Anthropic
# Console (Billing → Usage limits) — the hard backstop that caps the bill even
# if rate limiting is bypassed (SPEC_API_HARDENING §0).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- CORS allowlist (SPEC_API_HARDENING §2) ----------------------------------
# Comma-separated origins allowed to read API responses from a browser.
# No trailing slashes. If unset, the API falls back to the prod origin only.
# CORS is browser-enforced only — rate limiting is what protects the bill.
ALLOWED_ORIGINS=https://affina-space.vercel.app,http://localhost:5173
